# ─── App ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tsuser:tspassword@db:5432/talentstream
RABBITMQ_URL=amqp://tsuser:tspassword@rabbitmq:5672

# ─── Auth Feature Flag ────────────────────────────────────────────────────────
# Set to "true" to enforce Keycloak SSO. Set to "false" for local mock login.
AUTH_ENABLED=false

# ─── Keycloak (only needed when AUTH_ENABLED=true) ────────────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=talentstream
KEYCLOAK_CLIENT_ID=talentstream-backend
KEYCLOAK_CLIENT_SECRET=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_NAME=resumes

# ─── Hasura ───────────────────────────────────────────────────────────────────
HASURA_GRAPHQL_ADMIN_SECRET=mysecretkey
HASURA_GRAPHQL_ENDPOINT=http://localhost:8080

# ─── Internal ─────────────────────────────────────────────────────────────────
FASTAPI_INTERNAL_SECRET=internal-webhook-secret
