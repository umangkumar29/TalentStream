# ─── Auth Feature Flag ────────────────────────────────────────────────────────
# false = Demo role-picker (no Keycloak needed)
# true  = Keycloak SSO
VITE_AUTH_ENABLED=false

# ─── Keycloak (only used when VITE_AUTH_ENABLED=true) ─────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=talentstream
VITE_KEYCLOAK_CLIENT_ID=talentstream-frontend

# ─── Hasura ───────────────────────────────────────────────────────────────────
VITE_HASURA_ENDPOINT=http://localhost:8080/v1/graphql
VITE_HASURA_WS_ENDPOINT=ws://localhost:8080/v1/graphql
VITE_HASURA_ADMIN_SECRET=mysecretkey
